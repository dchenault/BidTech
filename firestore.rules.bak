
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // By default, deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // ========= HELPER FUNCTIONS =========
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // New RBAC Helper: Gets the membership document for the current user in a specific account
    function getMembership(accId) {
      return get(/databases/$(database)/documents/accounts/$(accId)/memberships/$(request.auth.uid)).data;
    }

    // Checks if the user has a specific role ('admin' or 'staff') in the account
    function hasRole(accId, role) {
      return isSignedIn() && getMembership(accId).role == role;
    }
    
    // Checks if a staff member has access to a specific auction
    function isAssignedToAuction(accId, auctionId) {
      return hasRole(accId, 'staff') && 
             (auctionId in getMembership(accId).assignedAuctions);
    }

    // ========= ROOT COLLECTIONS =========
    
    match /users/{userId} {
      // A user can create, read, and update their own profile.
      allow read, create, update: if isUser(userId);
    }
  
    // Invitations are temporary and grant access
    match /invitations/{inviteId} {
      // An admin can create, list, and delete invitations for their account.
      allow create, delete: if hasRole(request.resource.data.accountId, 'admin');
      allow list: if hasRole(request.query.accountId, 'admin');
      
      // The invited user can read their own invite to accept it.
      allow get: if getMembership(resource.data.accountId) != null || (isSignedIn() && request.auth.token.email == resource.data.email);
      
      // The invited user can update their invite to mark it as 'accepted'.
      allow update: if isSignedIn() && request.auth.token.email == resource.data.email;
    }

    match /accounts/{accountId} {
      // An authenticated user can create an account if they set themselves as the admin.
      allow create: if isUser(request.resource.data.adminUserId);
      
      // Only admins of an account can read or update its top-level details.
      allow read, update: if hasRole(accountId, 'admin');

      // --- Subcollections of an Account ---
      
      // Membership documents define roles.
      match /memberships/{userId} {
        // Admins can manage all memberships.
        allow read, write: if hasRole(accountId, 'admin');
        // A user can read their own membership to know their role.
        allow get: if isUser(userId);
      }
      
      // Patrons and Donors can be managed by any team member.
      match /patrons/{patronId} {
        allow read, write: if hasRole(accountId, 'admin') || hasRole(accountId, 'staff');
      }
      match /donors/{donorId} {
        allow read, write: if hasRole(accountId, 'admin') || hasRole(accountId, 'staff');
      }

      // Auctions and their subcollections have more granular rules.
      match /auctions/{auctionId} {
        // Public catalogs can be read by anyone. Staff and Admins can list.
        allow get: if resource.data.isPublic == true;
        allow list, get: if hasRole(accountId, 'admin') || hasRole(accountId, 'staff');
        
        // Only admins can create/delete/update the main auction document.
        allow create, update, delete: if hasRole(accountId, 'admin');
        
        // Rules for items, lots, etc. inside an auction.
        match /{subcollection}/{docId} {
            // Admins or staff assigned to this specific auction can read and write data.
            allow read, write: if hasRole(accountId, 'admin') || isAssignedToAuction(accountId, auctionId);
            // Deletion is restricted to admins only.
            allow delete: if hasRole(accountId, 'admin');
        }
      }
    }
  }
}
