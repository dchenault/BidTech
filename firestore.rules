rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========= HELPER FUNCTIONS =========
    function isSignedIn() {
      return request.auth != null;
    }

    // Combined Helper: Checks existence and role in one pass for better reliability
    function hasRole(accId, role) {
      let membershipPath = /databases/$(database)/documents/accounts/$(accId)/memberships/$(request.auth.uid);
      return isSignedIn() && 
             exists(membershipPath) && 
             get(membershipPath).data.role == role;
    }

    // Helper to get membership data for assignment checks
    function getMembership(accId) {
      return get(/databases/$(database)/documents/accounts/$(accId)/memberships/$(request.auth.uid)).data;
    }

    // ========= GLOBAL RULES =========
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // ========= ACCOUNT RULES =========
    match /accounts/{accountId} {
      
      // Allow admins to read/write the account document (Settings/Billing)
      allow read, write: if hasRole(accountId, 'admin');

      // Memberships sub-collection (Team Management)
      match /memberships/{membershipId} {
        // Allow users to read their own record (Crucial for Discovery/Login)
        allow read: if isSignedIn() && request.auth.uid == membershipId;
        
        // Only admins OR the original Account Owner can manage team memberships.
        // This ensures the owner never gets locked out of their own team settings.
        allow write: if isSignedIn() && (request.auth.uid == accountId || hasRole(accountId, 'admin'));
      }

      // Auctions
      match /auctions/{auctionId} {
        // Admins see all. Staff see only assigned auctions.
        allow read: if hasRole(accountId, 'admin') || 
                      (hasRole(accountId, 'staff') && auctionId in getMembership(accountId).assignedAuctions);
        
        // Only Admins can create/delete or modify high-level auction settings
        allow create, delete, update: if hasRole(accountId, 'admin');

        // Auction Data (Items, Bids, Categories, etc.)
        match /{allSubcollections=**} {
          allow read, create, update: if hasRole(accountId, 'admin') || 
                                         (hasRole(accountId, 'staff') && auctionId in getMembership(accountId).assignedAuctions);
          
          // Strict block on Staff deletions to protect data integrity
          allow delete: if hasRole(accountId, 'admin');
        }
      }

      // Global Master Data (Patrons/Donors)
      match /patrons/{patronId} {
        allow read, write: if hasRole(accountId, 'admin');
        allow read, create, update: if hasRole(accountId, 'staff');
      }

      match /donors/{donorId} {
        allow read, write: if hasRole(accountId, 'admin');
        allow read, create, update: if hasRole(accountId, 'staff');
      }
    }
    
    // Support for Collection Group Queries (Discovery)
    // Allows the useAccount hook to find any membership belonging to the user
    match /{path=**}/memberships/{membershipId} {
      allow read: if isSignedIn() && request.auth.uid == membershipId;
    }
  }
}