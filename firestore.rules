rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. GLOBAL SETTINGS
    // Deny everything by default to ensure no accidental leaks.
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. THE COLLECTION GROUP BYPASS
    // This allows searching for won items across ALL auctions for a single patron.
    // Crucial for the "Patron Detail" page to show their invoice.
    match /{path=**}/items/{itemId} {
      allow read, update: if true; 
    }

    // 3. THE PUBLIC STAFF & CATALOG BYPASS (Highest Priority)
    // Allows specific auction data to be managed without a Google login.
    match /accounts/{accountId}/auctions/{auctionId} {
      allow get: if true;
      
      // Unlock all data INSIDE the auction (lots, staff, registered_patrons, etc.)
      match /{allSubcollections=**} {
        allow read, write: if true; 
      }
    }

    // 4. THE "ORPHAN" DATA BYPASS
    // Patrons and Donors are stored at the Account level. Staff need access
    // to link them to items or register them for the auction.
    match /accounts/{accountId}/patrons/{patronId} {
      allow read, write: if true;
    }
    match /accounts/{accountId}/donors/{donorId} {
      allow read: if true;
    }

    // 5. THE OWNER/ADMIN RULES (Google Auth Required)
    // Protects individual user profile data.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Protects Account-level settings (billing, admin roles).
    match /accounts/{accountId} {
      allow read, write: if request.auth != null; 
    }

    match /patrons/{patronId} {
      allow read, write: if true;
    }
    
    // UPDATED: Allow staff to create/edit donors
    match /donors/{donorId} {
      allow read, write: if true;
    }
  }
}