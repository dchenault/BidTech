rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. GLOBAL SETTINGS
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. THE PUBLIC STAFF & CATALOG BYPASS (Highest Priority)
    // This allows specific auction-related data to be read via the ID
    match /accounts/{accountId}/auctions/{auctionId} {
      allow get: if true;
      
      // Unlock all data INSIDE the auction (items, lots, staff, registered_patrons)
      match /{allSubcollections=**} {
        allow read, write: if true; 
      }
    }

    // 3. THE "ORPHAN" DATA BYPASS
    // Patrons and Donors are often stored at the Account level, not the Auction level.
    // We must allow the Staff to 'get' these specific documents when they are linked to an item.
    match /accounts/{accountId}/patrons/{patronId} {
      allow read, write: if true;
    }
    match /accounts/{accountId}/donors/{donorId} {
      allow read: if true;
    }

    // 4. THE OWNER/ADMIN RULES (Google Auth Required)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // THIS IS THE KEY: Allow searching for won items across the whole database
    match /{path=**}/items/{itemId} {
      allow read: if true; 
    }

    // Ensure the specific auction path still has full access
    match /accounts/{accountId}/auctions/{auctionId} {
      allow read, write: if true;
      match /{allSubcollections=**} {
        allow read, write: if true;
      }
    }

    match /accounts/{accountId} {
      allow read, write: if request.auth != null; 
      // Note: We are simplifying this to 'any signed in user' temporarily 
      // to ensure you aren't locked out of your own data while we fix this.
    }
  }
}