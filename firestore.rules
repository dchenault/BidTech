rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // By default, deny all reads and writes
    match /{document=**} {
      allow read, write: if false;
    }

    // ========= HELPER FUNCTIONS =========
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // New RBAC Helper: Gets the membership document for the current user
    function getMembership(accId) {
      return get(/databases/$(database)/documents/accounts/$(accId)/memberships/$(request.auth.uid)).data;
    }

    // Checks if the user has a specific role ('admin' or 'staff') in the account
    function hasRole(accId, role) {
      return isSignedIn() && getMembership(accId).role == role;
    }

    // Checks if a staff member is explicitly assigned to a specific auction
    function isAssignedToAuction(accId, auctionId) {
      return hasRole(accId, 'staff') && 
             auctionId in getMembership(accId).assignedAuctions;
    }

    // ========= COLLECTION GROUP RULES =========
    
    // Allows Admins to see item data across the whole account.
    // Restricted for staff (they should only see items via the specific auction path).
    match /{path=**}/items/{itemId} {
      allow read: if hasRole(resource.data.accountId, 'admin');
    }

    // ========= ROOT COLLECTIONS =========
    
    match /users/{userId} {
      allow read, write: if isUser(userId);
    }
  
    match /accounts/{accountId} {
      // Allow creation during onboarding
      allow create: if isSignedIn() && request.resource.data.id == accountId;
      
      // Only Admins can see the main account document (settings/billing)
      allow read, update, delete: if hasRole(accountId, 'admin');

      // --- SUBCOLLECTIONS ---

      // Memberships: Only Admins can manage the team
      match /memberships/{userId} {
        allow read, write: if hasRole(accountId, 'admin');
        // Allow users to read their own membership to determine their role
        allow read: if isUser(userId);
      }
      
      // Master Patrons: Only Admins can see the global list. 
      // Staff can create/read/edit but only if they are assigned to an active auction.
      match /patrons/{patronId} {
          allow read, write: if hasRole(accountId, 'admin');
          allow create, read, update: if hasRole(accountId, 'staff'); 
          allow delete: if hasRole(accountId, 'admin');
      }

      // Master Donors: Only Admins can see the global list.
      match /donors/{donorId} {
          allow read, write: if hasRole(accountId, 'admin');
          allow create, read, update: if hasRole(accountId, 'staff');
          allow delete: if hasRole(accountId, 'admin');
      }
      
      match /auctions/{auctionId} {
        // Auction Visibility: 
        // 1. Admins see all. 
        // 2. Staff see only assigned auctions.
        // 3. Public get access (for catalogs).
        allow get: if true; 
        allow list: if hasRole(accountId, 'admin') || hasRole(accountId, 'staff');
        
        // Management: Only Admins can create/delete or close auctions.
        allow create, delete: if hasRole(accountId, 'admin');
        allow update: if hasRole(accountId, 'admin');

        // --- AUCTION DATA (items, registered_patrons, etc.) ---
        match /{subcollection}/{docId} {
            // Read access: Admin or Assigned Staff
            allow read, list: if hasRole(accountId, 'admin') || isAssignedToAuction(accountId, auctionId);
            
            // Write access: Admin or Assigned Staff
            allow create, update: if hasRole(accountId, 'admin') || isAssignedToAuction(accountId, auctionId);
            
            // Delete: STRICTLY Admins only
            allow delete: if hasRole(accountId, 'admin');
        }
      }
    }
  }
}