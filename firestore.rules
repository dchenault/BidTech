rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // ========= HELPER FUNCTIONS =========
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAccountAdmin(accountId) {
      let userProfile = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && userProfile.data.accounts[accountId] == 'admin';
    }

    function isAccountMember(accountId) {
      let userProfile = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && userProfile.data.accounts[accountId] != null;
    }

    // ========= ROOT COLLECTIONS =========
    
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /accounts/{accountId} {
      allow read: if isAccountMember(accountId);
      allow update, delete: if isAccountAdmin(accountId);
      allow create: if isSignedIn();

      // --- Subcollections of an Account (Global Patrons/Donors) ---
      match /patrons/{patronId} { allow read, write: if isAccountMember(accountId); }
      match /donors/{donorId} { allow read, write: if isAccountMember(accountId); }
      
      // ========= AUCTION SCOPE =========
      match /auctions/{auctionId} {
        
        // Helper: Check if User is Manager/Admin
        function isManager() {
          let auction = get(/databases/$(database)/documents/accounts/$(accountId)/auctions/$(auctionId));
          return isAccountAdmin(accountId) || (isSignedIn() && request.auth.uid in auction.data.managers);
        }

        // Helper: Check for Staff Session in Headers
        function isStaff() {
          let staffName = request.headers.staffname;
          return exists(/databases/$(database)/documents/accounts/$(accountId)/auctions/$(auctionId)/staff/$(staffName));
        }

        // Auction Document Permissions
        allow get: if true; // Publicly readable for catalog/staff login
        allow list, create: if isAccountMember(accountId);
        allow update: if isManager();
        allow delete: if isAccountAdmin(accountId);

        // Staff Collection: Handshake
        match /staff/{staffName} {
          allow get: if true; // Allows the login page to verify the username
          allow list, create, delete: if isManager();
        }

        // THE FIX: Items, Patrons, and Donations inside the Auction
        match /{subcollection}/{docId} {
          // Allow read/write if the user is a Manager OR if they have a valid Staff Username
          allow read, list, create, update: if isManager() || isStaff();
          allow delete: if isManager();
        }
      }
    }
  }
}