rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // ========= HELPER FUNCTIONS =========
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAccountAdmin(accountId) {
      // User's profile determines their role in an account.
      let userProfile = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && userProfile.data.accounts[accountId] == 'admin';
    }

    function isAccountMember(accountId) {
      // User's profile determines their role in an account.
      let userProfile = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isSignedIn() && userProfile.data.accounts[accountId] != null;
    }
    
    // ========= ROOT COLLECTIONS =========
    
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /accounts/{accountId} {
      allow read: if isAccountMember(accountId);
      allow update, delete: if isAccountAdmin(accountId);
      allow create: if isSignedIn();

      // --- Subcollections of an Account (Global Patrons/Donors) ---
      
      // This rule allows account members to manage patrons. It ALSO allows any
      // temporary staff member (signed in anonymously) to read/create/update
      // patrons, which is necessary for the staff portal functionality.
      match /patrons/{patronId} { 
        allow read, create, update: if isAccountMember(accountId) || (isSignedIn() && request.auth.token.firebase.sign_in_provider == 'anonymous');
        allow delete: if isAccountAdmin(accountId); // Only admins can delete patrons
      }
      
      match /donors/{donorId} { 
        allow read, write: if isAccountMember(accountId); 
      }
      
      // ========= AUCTION SCOPE =========
      match /auctions/{auctionId} {
        
        // Helper: Check if User is a permanent Manager or the Account Admin
        function isManager() {
          let auction = get(/databases/$(database)/documents/accounts/$(accountId)/auctions/$(auctionId));
          return isAccountAdmin(accountId) || (isSignedIn() && request.auth.uid in auction.data.managers);
        }

        // Helper: Check if user is an authorized staff member for THIS auction.
        // This is the secure handshake for the public staff portal.
        function isAuthorizedStaff() {
          return isSignedIn() &&
                 request.auth.token.firebase.sign_in_provider == 'anonymous' &&
                 exists(/databases/$(database)/documents/accounts/$(accountId)/auctions/$(auctionId)/staff/$(request.auth.uid));
        }

        // Auction Document Permissions
        allow get: if true; // Publicly readable for catalog/staff login
        allow list, create: if isAccountMember(accountId);
        allow update: if isManager();
        allow delete: if isAccountAdmin(accountId);

        // Staff Collection: Used for the initial username check.
        match /staff/{staffNameOrUid} {
          // Allows the login page to verify the username exists.
          allow get: if true;
          // Allows a manager to add/remove staff usernames.
          allow list, create, delete: if isManager();
          // Allows the anonymous user to create their temporary session document.
          allow create: if isSignedIn() && staffNameOrUid == request.auth.uid;
        }

        // Rules for all data within an auction (items, lots, etc.)
        match /{subcollection}/{docId} {
          allow read, list, create, update: if isManager() || isAuthorizedStaff();
          allow delete: if isManager(); // Staff cannot delete.
        }
      }
    }
  }
}
